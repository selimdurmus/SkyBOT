import torch
from google.colab import drive
from transformers import (GPT2Tokenizer, GPT2LMHeadModel, Trainer,
                          TrainingArguments, DataCollatorForLanguageModeling)
from datasets import load_dataset
import os

# 1. Google Drive'ı Bağla
if not os.path.exists('/content/drive'):
    drive.mount('/content/drive')

# --- DOSYA YOLLARI ---
# Drive'ındaki dosyanın tam yolunu buraya yaz (Genelde 'MyDrive' altındadır)
input_file = "/content/drive/MyDrive/trwiki_piril_piril.txt"
output_path = "/content/drive/MyDrive/gpt2_tr_final_model"
# ---------------------

# 2. Model ve Tokenizer Yükleme (355M = gpt2-medium A100 işlem birimi kullanırken sorun olmaz, ama T4 için 124M yani gpt2-small daha az uğraştırır)
# 355M modeli A100 işlem birimlerinde bile 15 saatte ancak %20 ye gelebiliyor) 
model_name = "gpt2-medium"
print(f"Modeller yükleniyor: {model_name}")

tokenizer = GPT2Tokenizer.from_pretrained(model_name)
tokenizer.pad_token = tokenizer.eos_token
model = GPT2LMHeadModel.from_pretrained(model_name)

# 3. Veriyi Yükleme ve Tokenize Etme
print(f"Veri yükleniyor: {input_file}")
dataset = load_dataset("text", data_files={"train": input_file})

def tokenize_function(examples):
    return tokenizer(examples["text"], truncation=True, max_length=512)

tokenized_datasets = dataset.map(
    tokenize_function,
    batched=True,
    num_proc=4,
    remove_columns=["text"]
)

data_collator = DataCollatorForLanguageModeling(tokenizer=tokenizer, mlm=False)

# 4. Eğitim Ayarları (A100 ve Drive Kaydı İçin Optimize Edildi)
training_args = TrainingArguments(
    output_dir="./checkpoints",    # Checkpoint'ler geçici olarak yerel diskte kalsın (hız için)
    num_train_epochs=1,
    per_device_train_batch_size=64, # A100/L24 için 16 idealdir
    gradient_accumulation_steps=4,
    learning_rate=5e-5,
    fp16=True,                     # GPU hızlandırma
    gradient_checkpointing=True,   # RAM koruması
    logging_steps=100,
    save_steps=2000,
    save_total_limit=2,
    weight_decay=0.01,
    report_to="none"
)

# 5. Eğiticiyi Başlat
trainer = Trainer(
    model=model,
    args=training_args,
    train_dataset=tokenized_datasets["train"],
    data_collator=data_collator,
)

print("🚀 Eğitim başlıyor! Drive'daki pırıl pırıl veriler işleniyor...")
trainer.train()

# 6. Modeli Doğrudan Drive'a Kaydet
trainer.save_model(output_path)
tokenizer.save_pretrained(output_path)
print(f"✅ EĞİTİM BİTTİ! Modelin şu konuma kaydedildi: {output_path}")
